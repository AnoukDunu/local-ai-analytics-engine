# in the previous project, I used a database.ini file to store database credentials. 
# In this project, I will use a .env file to store all my environment variables, including database credentials, API keys, etc. 
# This is a more secure way to manage sensitive information and is more of a standard practice. This is why

DB_HOST=localhost
DB_NAME=etl_db
DB_USER=postgres
DB_PASSWORD=abc123